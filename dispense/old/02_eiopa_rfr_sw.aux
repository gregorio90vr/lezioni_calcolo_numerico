\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Effetto del parametro $\alpha $ sulla forma del kernel (nodo $u=10$ fisso). Un $\alpha $ piccolo produce un kernel pi\`u ampio e lento a decadere: la curva impiega pi\`u tempo a convergere verso l'UFR. Un $\alpha $ grande produce un kernel stretto e rapido.}}{15}{figure.2}\protected@file@percent }
\newlabel{fig:kernel_alpha}{{2}{15}{Effetto del parametro $\alpha $ sulla forma del kernel (nodo $u=10$ fisso). Un $\alpha $ piccolo produce un kernel pi\`u ampio e lento a decadere: la curva impiega pi\`u tempo a convergere verso l'UFR. Un $\alpha $ grande produce un kernel stretto e rapido}{figure.2}{}}
