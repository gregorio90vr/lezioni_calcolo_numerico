\@writefile{lof}{\contentsline {figure}{\numberline {17}{\ignorespaces La ``prova'' visiva (dicembre~2025): scarto per scadenza dei due strumenti rispetto ai par rate impliciti EIOPA. \texttt  {EUSA*} (EURIBOR) collassa nella banda $\pm 2$~bps (input corretto); \texttt  {EESWE*} (\texteuro {}STR) resta $\approx 20$--$25$~bps sotto. Il \emph  {segno} e la \emph  {forma decrescente} dello scarto \texttt  {EESWE} sono la firma del basis EURIBOR--\texteuro {}STR.}}{35}{figure.17}\protected@file@percent }
\newlabel{fig:eusa-basis}{{17}{35}{La ``prova'' visiva (dicembre~2025): scarto per scadenza dei due strumenti rispetto ai par rate impliciti EIOPA. \texttt {EUSA*} (EURIBOR) collassa nella banda $\pm 2$~bps (input corretto); \texttt {EESWE*} (\texteuro {}STR) resta $\approx 20$--$25$~bps sotto. Il \emph {segno} e la \emph {forma decrescente} dello scarto \texttt {EESWE} sono la firma del basis EURIBOR--\texteuro {}STR}{figure.17}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {18}{\ignorespaces \textbf  {Banda delle differenze} (ricostruzione SW su \texttt  {EUSA*} $-$ ufficiale EIOPA) sui dodici fine-mese del~2025: la regione ombreggiata \`e l'inviluppo \emph  {min--max} per scadenza, la linea \`e la media. In zona liquida ($T\le \ensuremath  {\mathrm  {LLP}}$) la banda \`e contenuta entro pochi bps attorno allo zero; oltre il \ensuremath  {\mathrm  {LLP}}{} si allarga per effetto del divario $\alpha $-criterio vs $\alpha $-ufficiale (cfr.\ Tabella~\ref {tab:rmse-eusa}), restando comunque di pochi bps. Prodotta da \texttt  {R/curva\_eiopa\_rfr\_CN\ -\ sw.R} (Sez.~9).}}{35}{figure.18}\protected@file@percent }
\newlabel{fig:eusa-banda}{{18}{35}{\textbf {Banda delle differenze} (ricostruzione SW su \texttt {EUSA*} $-$ ufficiale EIOPA) sui dodici fine-mese del~2025: la regione ombreggiata \`e l'inviluppo \emph {min--max} per scadenza, la linea \`e la media. In zona liquida ($T\le \LLP $) la banda \`e contenuta entro pochi bps attorno allo zero; oltre il \LLP {} si allarga per effetto del divario $\alpha $-criterio vs $\alpha $-ufficiale (cfr.\ Tabella~\ref {tab:rmse-eusa}), restando comunque di pochi bps. Prodotta da \texttt {R/curva\_eiopa\_rfr\_CN\ -\ sw.R} (Sez.~9)}{figure.18}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces \textbf  {Differenze SW(EUSA) $-$ ufficiale EIOPA per tenor e mese (2025).} Ogni barra rappresenta lo scarto in bps tra la curva spot ricostruita con Smith--Wilson su \texttt  {EUSA*} (con $\alpha =\alpha _{\rm  uff}$) e la curva spot ufficiale pubblicata da EIOPA, valutato ai 15 tenor DLT ufficiali $\{1,\ldots  ,13,15,20\}$ anni. Le barre arancioni indicano scarto positivo (ricostruita $>$ ufficiale), le barre blu scarto negativo. Le linee tratteggiate segnano la soglia $\pm 2$~bps. Si osserva che: \emph  {(i)} nella prima met\`a del~2025 (gennaio--maggio) prevale uno scarto sistematico positivo di $\approx 1$--$2$~bps, imputabile al divario $\alpha _{\rm  crit}\ne  \alpha _{\rm  uff}$ e a un lieve basis residuo sull'input EUSA; \emph  {(ii)} dalla seconda met\`a del~2025 (giugno--dicembre) i due $\alpha $ quasi coincidono e gli scarti scendono ben al di sotto del bp per la quasi totalit\`a dei tenor. Prodotta da \texttt  {R/curva\_eiopa\_rfr\_CN\ -\ sw.R} (Sez.~9).}}{36}{figure.19}\protected@file@percent }
\newlabel{fig:eusa-barre}{{19}{36}{\textbf {Differenze SW(EUSA) $-$ ufficiale EIOPA per tenor e mese (2025).} Ogni barra rappresenta lo scarto in bps tra la curva spot ricostruita con Smith--Wilson su \texttt {EUSA*} (con $\alpha =\alpha _{\rm uff}$) e la curva spot ufficiale pubblicata da EIOPA, valutato ai 15 tenor DLT ufficiali $\{1,\ldots ,13,15,20\}$ anni. Le barre arancioni indicano scarto positivo (ricostruita $>$ ufficiale), le barre blu scarto negativo. Le linee tratteggiate segnano la soglia $\pm 2$~bps. Si osserva che: \emph {(i)} nella prima met\`a del~2025 (gennaio--maggio) prevale uno scarto sistematico positivo di $\approx 1$--$2$~bps, imputabile al divario $\alpha _{\rm crit}\ne \alpha _{\rm uff}$ e a un lieve basis residuo sull'input EUSA; \emph {(ii)} dalla seconda met\`a del~2025 (giugno--dicembre) i due $\alpha $ quasi coincidono e gli scarti scendono ben al di sotto del bp per la quasi totalit\`a dei tenor. Prodotta da \texttt {R/curva\_eiopa\_rfr\_CN\ -\ sw.R} (Sez.~9)}{figure.19}{}}
