\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Estrapolazioni a confronto, luglio~2025. Due spline cubiche (naturale e \texttt  {fmm}) costruite sugli stessi 15 tassi spot liquidi: coincidono con la curva ufficiale EIOPA (blu) per $T \le \ensuremath  {\mathrm  {LLP}}$, ma divergono in modo arbitrario nella zona di estrapolazione (grigia), nessuna convergendo all'$\ensuremath  {\mathrm  {UFR}}= 3.30\%$ (linea viola).}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:spline-sw}{{3}{9}{Estrapolazioni a confronto, luglio~2025. Due spline cubiche (naturale e \texttt {fmm}) costruite sugli stessi 15 tassi spot liquidi: coincidono con la curva ufficiale EIOPA (blu) per $T \le \LLP $, ma divergono in modo arbitrario nella zona di estrapolazione (grigia), nessuna convergendo all'$\UFR = 3.30\%$ (linea viola)}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Scarti spline $-$ EIOPA ufficiale, luglio~2025. Ogni barra rappresenta la differenza in punti base tra il tasso spot della spline e quello della curva ufficiale EIOPA ai tenor interi $1$--$60$ anni. Nella zona liquida ($T \le \ensuremath  {\mathrm  {LLP}}$, barre blu) gli scarti sono contenuti; oltre il $\ensuremath  {\mathrm  {LLP}}$ (barre rosse) le due spline divergono dall'EIOPA in misura crescente, con segni opposti a seconda della condizione al contorno.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:spline-delta}{{4}{9}{Scarti spline $-$ EIOPA ufficiale, luglio~2025. Ogni barra rappresenta la differenza in punti base tra il tasso spot della spline e quello della curva ufficiale EIOPA ai tenor interi $1$--$60$ anni. Nella zona liquida ($T \le \LLP $, barre blu) gli scarti sono contenuti; oltre il $\LLP $ (barre rosse) le due spline divergono dall'EIOPA in misura crescente, con segni opposti a seconda della condizione al contorno}{figure.4}{}}
