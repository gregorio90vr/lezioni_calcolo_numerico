\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Estrapolazioni a confronto, luglio~2025. Due spline cubiche (naturale e \texttt  {fmm}) costruite sugli stessi tassi liquidi ai 15 nodi DLT: coincidono per $T \le \ensuremath  {\mathrm  {LLP}}$ ma divergono in modo arbitrario nella zona di estrapolazione (grigia), nessuna convergendo all'$\ensuremath  {\mathrm  {UFR}}$. La curva Smith--Wilson (blu) \`e invece costruita attorno all'$\ensuremath  {\mathrm  {UFR}}= 3.30\%$ (linea viola), verso cui converge.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:spline-sw}{{3}{8}{Estrapolazioni a confronto, luglio~2025. Due spline cubiche (naturale e \texttt {fmm}) costruite sugli stessi tassi liquidi ai 15 nodi DLT: coincidono per $T \le \LLP $ ma divergono in modo arbitrario nella zona di estrapolazione (grigia), nessuna convergendo all'$\UFR $. La curva Smith--Wilson (blu) \`e invece costruita attorno all'$\UFR = 3.30\%$ (linea viola), verso cui converge}{figure.3}{}}
